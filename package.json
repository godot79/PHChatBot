{
  "name": "physio-chatbot",
  "version": "1.0.0",
  "description": "Physiotherapy chatbot with Cliniko integration and phone verification",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest"
  },
  "keywords": [
    "physiotherapy",
    "chatbot",
    "cliniko",
    "healthcare",
    "appointment"
  ],
  "author": "Godot",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "base-64": "^1.0.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "npm": "^11.4.2",
    "sqlite3": "^5.1.6",
    "validator": "^13.15.15",
    "winston": "^3.17.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^30.0.5",
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/unit/**/*.test.js",
      "<rootDir>/tests/integration/**/*.test.js"
    ],
    "forceExit": true
  },
  "allowScripts": {
    "sqlite3@5.1.7": true,
    "bcrypt@5.1.1": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.11.1": true
  }
}
